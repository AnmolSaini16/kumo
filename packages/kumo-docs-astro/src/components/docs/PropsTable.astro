---
/**
 * PropsTable - Renders a props table from the component registry or manual definitions.
 *
 * Usage:
 *   <PropsTable component="Button" />
 *   <PropsTable component="Dialog.Root" />
 *   <PropsTable props={{ name: { type: "string", description: "...", required: true } }} />
 */

import {
  getComponentData,
  formatPropType,
  formatDefault,
  type PropSchema,
} from "~/lib/component-registry";

interface ManualPropDef {
  /** Type as a display string, e.g. "string", "boolean", '"up" | "down"' */
  type: string;
  /** Description text (HTML is supported) */
  description?: string;
  /** Whether this prop is required */
  required?: boolean;
  /** Default value as a display string */
  default?: string;
}

interface Props {
  /** Component name for registry lookup (e.g., "Button" or "Dialog.Root") */
  component?: string;
  /** Manual prop definitions — bypasses registry lookup when provided */
  props?: Record<string, ManualPropDef>;
  /** Whether to hide the description column (default: false) */
  hideDescription?: boolean;
}

const { component, props: manualProps, hideDescription = false } = Astro.props;

// Filter out props that are typically inherited and not useful to document
const HIDDEN_PROPS = new Set(["ref", "key"]);

// Registry lookup (only when component is specified and no manual props)
const data = !manualProps && component ? getComponentData(component) : null;

// Normalize into a flat display-ready shape
interface DisplayProp {
  name: string;
  type: string;
  defaultValue: string;
  description: string;
  isRequired: boolean;
}

let displayProps: DisplayProp[];

if (manualProps) {
  displayProps = Object.entries(manualProps).map(([name, def]) => ({
    name,
    type: def.type,
    defaultValue: def.default ?? "-",
    description: def.description ?? "",
    isRequired: def.required === true,
  }));
} else if (data) {
  displayProps = Object.entries(data.props)
    .filter(([name]) => !HIDDEN_PROPS.has(name))
    .map(([name, prop]) => ({
      name,
      type: formatPropType(prop),
      defaultValue: formatDefault(prop),
      description: prop.description ?? "",
      isRequired: prop.required === true || prop.optional === false,
    }));
} else {
  displayProps = [];
}

const hasData = !!(manualProps || data);

// Check if any props have descriptions to show the column
const hasDescriptions =
  !hideDescription && displayProps.some((p) => p.description);
---

{
  hasData ? (
    <div class="not-prose overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-kumo-hairline">
            <th class="px-4 py-3 text-left font-semibold">Prop</th>
            <th class="px-4 py-3 text-left font-semibold">Type</th>
            <th class="px-4 py-3 text-left font-semibold">Default</th>
            {hasDescriptions && (
              <th class="px-4 py-3 text-left font-semibold">Description</th>
            )}
          </tr>
        </thead>
        <tbody class="text-kumo-strong">
          {displayProps.map((prop) => (
            <tr class="border-b border-kumo-hairline">
              <td class="px-4 py-3 font-mono text-xs">
                {prop.name}
                {prop.isRequired && <span class="text-kumo-danger ml-0.5">*</span>}
              </td>
              <td class="px-4 py-3 font-mono text-xs max-w-xs">
                <code class="text-wrap break-words">{prop.type}</code>
              </td>
              <td class="px-4 py-3 font-mono text-xs">
                {prop.defaultValue !== "-" ? <code>{prop.defaultValue}</code> : "-"}
              </td>
              {hasDescriptions && (
                <td class="px-4 py-3 text-xs max-w-md" set:html={prop.description || "-"} />
              )}
            </tr>
          ))}
        </tbody>
      </table>
      {displayProps.length === 0 && (
        <p class="px-4 py-3 text-sm text-kumo-subtle">
          No component-specific props. Accepts standard HTML attributes.
        </p>
      )}
    </div>
  ) : component ? (
    <div class="rounded-lg border border-kumo-danger/20 bg-kumo-danger/5 p-4">
      <p class="text-sm text-kumo-danger">
        Component "{component}" not found in registry. Run{" "}
        <code>pnpm build:ai-metadata</code> to regenerate.
      </p>
    </div>
  ) : null
}
